# Пример конфигурации окружения Market Terminal.
# Скопируйте в `.env` и подставьте свой долгоживущий секрет Finam Trade API.
# Файл `.env` в `.gitignore` и в репозиторий не попадает.
#
# Принимаются оба имени ключа (без учёта регистра): FINAM_API_SECRET или FINAM_SECRET.
FINAM_API_SECRET=tapi_sk_xxxxxxxxxxxxxxxxxxxxxx

# Ключ MOEX ALGOPACK (фаза 10): подписка на data.moex.com → APIKEY.
# Используется как заголовок `Authorization: Bearer <ключ>` к apim.moex.com.
MOEX_ALGO_API=xxxxxxxxxxxxxxxxxxxxxxxx

# Биржа для справочника инструментов (по умолчанию MISX).
# FINAM_MIC=MISX

# ── LLM-провайдеры для ИИ-резюме Key Activity (фаза 10.4, фича `llm`) ────────
# Нужен ключ только того провайдера, который выбран в настройках терминала
# (по умолчанию — OpenRouter). Без ключа панель «ИТОГО» показывает локальный
# текстовый свод (грациозная деградация). Ключи ищутся: переменная окружения →
# этот `.env` → ОС-keyring; в логи и ошибки они не попадают.

# OpenRouter (провайдер по умолчанию): https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
