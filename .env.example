# Пример конфигурации окружения Market Terminal.
# Скопируйте в `.env` и подставьте свой долгоживущий секрет Finam Trade API.
# Файл `.env` в `.gitignore` и в репозиторий не попадает.
#
# Принимаются оба имени ключа (без учёта регистра): FINAM_API_SECRET или FINAM_SECRET.
FINAM_API_SECRET=tapi_sk_xxxxxxxxxxxxxxxxxxxxxx

# Ключ MOEX ALGOPACK (фаза 10): подписка на data.moex.com → APIKEY.
# Используется как заголовок `Authorization: Bearer <ключ>` к apim.moex.com.
MOEX_ALGO_API=xxxxxxxxxxxxxxxxxxxxxxxx

# Биржа для справочника инструментов (по умолчанию MISX).
# FINAM_MIC=MISX
