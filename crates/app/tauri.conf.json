{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Market Terminal",
  "version": "0.1.0",
  "identifier": "ru.market.terminal",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../../frontend run dev",
    "beforeBuildCommand": "npm --prefix ../../frontend run build",
    "features": ["tauri"]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Market Terminal",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "Market Terminal",
    "category": "Finance",
    "shortDescription": "Аналитический терминал рыночных данных (Finam Trade API)",
    "longDescription": "Десктопный read-only терминал: оборот, денежные потоки, секторная ротация и кросс-актив по акциям, фьючерсам и облигациям. Заявки не выставляются.",
    "copyright": "© 2026 Market Terminal",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "languages": ["Russian", "English"]
      }
    }
  }
}
